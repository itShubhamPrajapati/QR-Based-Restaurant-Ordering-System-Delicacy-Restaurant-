# =========================================================================
# Delicacy Restaurant - Frontend Environment Variables Template
# Copy this file to .env and configure the values for local development.
# For production (Vercel), configure these variables directly in the Vercel dashboard.
# =========================================================================

# API Configuration
# Local Development: http://localhost:8000
# Production: Set this to your deployed Railway backend URL (e.g., https://your-backend.railway.app)
VITE_API_URL=http://localhost:8000

# Razorpay Payment Key (Get from Razorpay Dashboard: https://dashboard.razorpay.com)
# For local testing, use the same test key configured on the backend.
VITE_RAZORPAY_KEY_ID=rzp_test_SEULnJj6ZBfPb4
